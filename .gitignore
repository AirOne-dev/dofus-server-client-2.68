**/bin/
**/obj/
**/.build/
**/.swiftpm/
*.dSYM/
*.user
server/build/
server/run/
server/logs/
server/web/oneair-web

# SwiftPM symlinks générés à la volée (cf. client/OneAirLauncher/Package.swift)
client/OneAirLauncher/Sources/

# Données runtime
data/
Dofus\ Stump.app/

# Logs / backups
*.log
*.bak
.DS_Store

