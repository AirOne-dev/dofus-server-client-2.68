<Window x:Class="OneAirLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OneAirLauncher"
        Title="One Air"
        Width="540" Height="620"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <!-- ===================== Style: bouton ghost (footer) ===================== -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== Style: bouton fermeture titlebar ===================== -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33d97757"/>
                                <Setter Property="Foreground" Value="{StaticResource RedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== Style: champ texte stylé (équivalent IconTextField) ===================== -->
        <Style x:Key="GoldTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource GoldBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="36,0,12,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GoldPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource GoldBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="36,0,56,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== Style: bouton JOUER (gold) ===================== -->
        <Style x:Key="GoldPlayButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource GoldBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DarkOnGoldBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GoldPressBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource GoldHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource GoldPressBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== Style: bouton outline (Cancel/Save dans Advanced) ===================== -->
        <Style x:Key="GoldOutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===================== Toggle VOIR/CACHER mot de passe ===================== -->
        <Style x:Key="PasswordToggleButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSoftBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- =============== Background : portail flouté + dim =============== -->
        <Image x:Name="BgImage"
               Source="Assets/portal-bg.jpg"
               Stretch="UniformToFill"
               Opacity="0.55">
            <Image.Effect>
                <BlurEffect Radius="18"/>
            </Image.Effect>
        </Image>
        <Rectangle Fill="#8c0a0703"/>

        <!-- =============== Title bar custom (drag + close) =============== -->
        <Grid VerticalAlignment="Top" Height="28" Background="Transparent"
              MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="One Air" Margin="14,6,0,0"
                       Foreground="{StaticResource TextSoftBrush}" FontSize="11" FontWeight="Medium"/>
            <Button Grid.Column="1" Style="{StaticResource CloseButton}" Content="✕" Click="Close_Click"/>
        </Grid>

        <!-- =============== Carte centrée =============== -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">
            <!-- Logo -->
            <Image Source="Assets/logo.png" Width="200" Height="100"
                   Stretch="Uniform" Margin="0,0,0,4"/>

            <!-- Tagline -->
            <TextBlock Text="ÉDITION DU VOYAGEUR"
                       Foreground="{StaticResource TextDimBrush}"
                       FontSize="9" FontWeight="Medium"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16">
                <TextBlock.RenderTransform>
                    <TranslateTransform/>
                </TextBlock.RenderTransform>
                <TextBlock.LayoutTransform>
                    <ScaleTransform/>
                </TextBlock.LayoutTransform>
            </TextBlock>

            <!-- COMPTE -->
            <TextBlock Text="COMPTE" Foreground="{StaticResource TextDimBrush}"
                       FontSize="10" FontWeight="Medium" Margin="0,0,0,4"/>

            <!-- Account selector custom -->
            <Border x:Name="AccountSelector" Height="38"
                    Background="{StaticResource InputBgBrush}"
                    BorderBrush="{StaticResource InputBorderBrush}"
                    BorderThickness="1" CornerRadius="4"
                    Cursor="Hand"
                    MouseLeftButtonDown="AccountSelector_MouseDown"
                    MouseEnter="AccountSelector_MouseEnter"
                    MouseLeave="AccountSelector_MouseLeave">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="AccountIcon"
                               Grid.Column="0" Text="&#xE77B;"
                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource TextSoftBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock x:Name="AccountText" Grid.Column="1"
                               Text="+ Nouveau compte"
                               Foreground="{StaticResource TextSoftBrush}"
                               FontSize="13" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="AccountChevron" Grid.Column="2" Text="&#xE70D;"
                               FontFamily="Segoe MDL2 Assets" FontSize="9"
                               Foreground="{StaticResource TextSoftBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="AccountChevronRotate" Angle="0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Popup dropdown comptes -->
            <Popup x:Name="AccountPopup" PlacementTarget="{Binding ElementName=AccountSelector}"
                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                <Border Background="{StaticResource Bg2Brush}"
                        BorderBrush="{StaticResource BorderStrongBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Width="358" Padding="0,6">
                    <StackPanel x:Name="AccountList"/>
                </Border>
            </Popup>

            <!-- Container login/password (cachable quand un compte est sélectionné) -->
            <StackPanel x:Name="InputsContainer" Margin="0,16,0,0">
                <TextBlock Text="IDENTIFIANT" Foreground="{StaticResource TextDimBrush}"
                           FontSize="10" FontWeight="Medium" Margin="0,0,0,4"/>
                <Grid>
                    <TextBox x:Name="UserField" Style="{StaticResource GoldTextBox}"
                             KeyDown="Field_KeyDown"/>
                    <TextBlock x:Name="UserPlaceholder"
                               Text="Votre nom de compte"
                               IsHitTestVisible="False"
                               Foreground="{StaticResource TextSoftBrush}" FontSize="13"
                               Margin="40,0,0,0" VerticalAlignment="Center"
                               Visibility="Visible"/>
                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{StaticResource TextSoftBrush}"
                               Margin="14,0,0,0" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Grid>

                <TextBlock Text="MOT DE PASSE" Foreground="{StaticResource TextDimBrush}"
                           FontSize="10" FontWeight="Medium" Margin="0,12,0,4"/>
                <Grid>
                    <PasswordBox x:Name="PassField" Style="{StaticResource GoldPasswordBox}"
                                 PasswordChanged="PassField_Changed"
                                 KeyDown="Field_KeyDown"/>
                    <TextBox x:Name="PassFieldVisible"
                             Style="{StaticResource GoldTextBox}"
                             Padding="36,0,56,0"
                             Visibility="Collapsed"
                             KeyDown="Field_KeyDown"/>
                    <TextBlock x:Name="PassPlaceholder"
                               Text="••••••••••"
                               IsHitTestVisible="False"
                               Foreground="{StaticResource TextSoftBrush}" FontSize="13"
                               Margin="40,0,0,0" VerticalAlignment="Center"
                               Visibility="Visible"/>
                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{StaticResource TextSoftBrush}"
                               Margin="14,0,0,0" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <Button x:Name="PassToggle" Content="VOIR"
                            Style="{StaticResource PasswordToggleButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0" Click="PassToggle_Click"/>
                </Grid>

                <CheckBox x:Name="RememberCheck" Margin="0,12,0,0" IsChecked="True"
                          Foreground="{StaticResource TextDimBrush}" FontSize="12">
                    <TextBlock Text="Se souvenir de moi"/>
                </CheckBox>
            </StackPanel>

            <!-- Play -->
            <Button x:Name="PlayButton" Style="{StaticResource GoldPlayButton}"
                    Margin="0,16,0,0" Click="PlayButton_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="PlayLabel" Text="JOUER" FontSize="13"
                               FontWeight="SemiBold" Foreground="{StaticResource DarkOnGoldBrush}"
                               VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock x:Name="PlayArrow" Text="  →" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource DarkOnGoldBrush}"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
            </Button>

            <!-- Separator -->
            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,12,0,8"/>

            <!-- Footer (Options avancées + status) -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Left" Click="Advanced_Click">
                    <TextBlock>
                        <Run Text="⚙   "/>
                        <Run Text="OPTIONS AVANCÉES"/>
                    </TextBlock>
                </Button>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="6" Height="6"
                             Fill="{StaticResource GreenBrush}"
                             VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusLabel" Text="En ligne" FontSize="10"
                               FontFamily="Consolas"
                               Foreground="{StaticResource TextSoftBrush}"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
