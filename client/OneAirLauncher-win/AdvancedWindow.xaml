<Window x:Class="OneAirLauncher.AdvancedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options avancées"
        Width="380" Height="290"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource Bg2Brush}"
        FontFamily="Segoe UI">
    <Border BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="OPTIONS AVANCÉES"
                           Foreground="{StaticResource TextDimBrush}"
                           FontSize="10" FontWeight="Medium"/>
                <Button Grid.Column="1" Content="✕" Width="24" Height="24"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource TextSoftBrush}"
                        Cursor="Hand" Click="Close_Click"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="IP / DNS DU SERVEUR"
                           Foreground="{StaticResource TextDimBrush}"
                           FontSize="9" FontWeight="Medium"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="PORT"
                           Margin="8,0,0,0"
                           Foreground="{StaticResource TextDimBrush}"
                           FontSize="9" FontWeight="Medium"/>
                <TextBox x:Name="IpField" Grid.Row="1" Grid.Column="0" Margin="0,4,0,0"
                         Height="28" FontSize="12"
                         Background="{StaticResource InputBgBrush}"
                         Foreground="{StaticResource TextBrush}"
                         BorderBrush="{StaticResource InputBorderBrush}"
                         BorderThickness="1" Padding="8,0"
                         VerticalContentAlignment="Center"/>
                <TextBox x:Name="PortField" Grid.Row="1" Grid.Column="1" Margin="8,4,0,0"
                         Height="28" FontSize="12"
                         Background="{StaticResource InputBgBrush}"
                         Foreground="{StaticResource TextBrush}"
                         BorderBrush="{StaticResource InputBorderBrush}"
                         BorderThickness="1" Padding="8,0"
                         VerticalContentAlignment="Center"/>
            </Grid>

            <Button x:Name="TestButton" Grid.Row="2" Margin="0,12,0,0"
                    Height="30"
                    Background="Transparent"
                    Foreground="{StaticResource GoldBrush}"
                    BorderBrush="{StaticResource BorderStrongBrush}"
                    BorderThickness="1"
                    FontSize="10" FontWeight="Medium"
                    Cursor="Hand"
                    Content="TESTER LA CONNEXION"
                    Click="Test_Click"/>

            <TextBlock x:Name="ResultLabel" Grid.Row="3" Margin="0,8,0,0"
                       Text="— aucun test effectué"
                       FontFamily="Consolas" FontSize="10"
                       Foreground="{StaticResource TextSoftBrush}"/>

            <Border Grid.Row="4" Height="1" VerticalAlignment="Bottom"
                    Background="{StaticResource BorderBrush}"
                    Margin="0,0,0,12"/>

            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="ANNULER" Margin="0,0,4,0"
                        Height="30" FontSize="10" FontWeight="Medium"
                        Background="Transparent"
                        Foreground="{StaticResource TextDimBrush}"
                        BorderBrush="{StaticResource BorderStrongBrush}"
                        BorderThickness="1" Cursor="Hand"
                        Click="Cancel_Click"/>
                <Button Grid.Column="1" Content="ENREGISTRER" Margin="4,0,0,0"
                        Height="30" FontSize="10" FontWeight="SemiBold"
                        Background="{StaticResource GoldBrush}"
                        Foreground="{StaticResource DarkOnGoldBrush}"
                        BorderThickness="0" Cursor="Hand"
                        Click="Save_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
