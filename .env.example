# =============================================================================
#  Configuration OneAir / Giny — copie en .env
# =============================================================================

# --- MySQL ------------------------------------------------------------------
# Génère des mots de passe forts : openssl rand -base64 24 | tr -d /+=
MYSQL_ROOT_PASSWORD=changeme-rootpw
MYSQL_USER=giny
MYSQL_PASSWORD=changeme-giny
MYSQL_AUTH_DB=giny_auth
MYSQL_WORLD_DB=giny_world
MYSQL_PORT=3306

# --- Réseau exposé au client Dofus -----------------------------------------
# SERVER_HOST       : adresse que le client Dofus va contacter (IP ou DNS).
#                     127.0.0.1 = serveur local sur cette même machine.
#                     Sinon : ip publique / ipv4 LAN / nom DNS.
# PUBLIC_AUTH_PORT  : port hôte exposé par Docker pour l'auth (>1024 = pas sudo).
# PUBLIC_WORLD_PORT : port hôte exposé pour le world.
# SERVER_DISPLAY_NAME : libellé interne dans config.xml (cosmétique, jamais
#                       affiché à l'utilisateur).
# AUTH_PORT/WORLD_PORT : ports INTERNES au conteneur Giny (ne change pas).
SERVER_HOST=127.0.0.1
SERVER_DISPLAY_NAME=OneAir
PUBLIC_AUTH_PORT=5555
PUBLIC_WORLD_PORT=5556
AUTH_PORT=5555
WORLD_PORT=5556

# --- IPC (auth ↔ world, interne docker network) ----------------------------
IPC_PORT=800
AUTH_API_PORT=9001
WORLD_API_PORT=9000

# --- Identité du monde -----------------------------------------------------
# Le SWF override le nom côté client pour Id=291 → "One Air" (cf. patch
# Server.name dans DofusInvoker-patched.swf). Si tu changes WORLD_ID,
# il faut aussi mettre à jour la row world_servers en DB ET le getter du SWF.
WORLD_ID=291
WORLD_NAME="One Air"
WELCOME_MESSAGE="━━━━━━━  Bienvenue sur <b>OneAir</b>  ━━━━━━━\nServeur Dofus 2.68 privé, communautaire et 100% gratuit.\n\n<b>Commandes utiles</b> :\n  • <b>.online</b> — ouvre le panneau des joueurs en ligne\n  • <b>.who</b> — liste des connectés en chat\n  • <b>.help</b> — toutes les commandes disponibles\n\nAmuse-toi bien et n'hésite pas à signaler les bugs sur place. Bon jeu !"

# --- Multipliers gameplay --------------------------------------------------
JOB_RATE=1
DROP_RATE=1
XP_RATE=1

# --- Site web OneAir (landing publique + admin) ---------------------------
# Sert : landing publique, articles, login joueur, panel admin (Role>=5 sur
# accounts) et reverse-proxy dbgate. WEB_SESSION_KEY signe TOUS les cookies
# (joueur ET admin) — secret, à protéger.
# L'auth admin n'utilise PAS de couple username/password séparé : c'est le
# même login que les joueurs (/api/public/login) avec un compte qui a Role>=5
# dans giny_auth.accounts. Promotion via : scripts/create-account.sh user pw 5
# Génère WEB_SESSION_KEY via : openssl rand -hex 32
WEB_PORT=3000
WEB_SESSION_KEY=a4a247848dc21aa1a77c97a659bf7512d281869e5a1573cce237cc9661856a0c

# --- Backups DB -------------------------------------------------------------
BACKUP_INTERVAL_SECONDS=300
BACKUP_KEEP_COUNT=20
